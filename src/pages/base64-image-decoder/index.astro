---
import ToolLayout from '../../layouts/ToolLayout.astro';
---
<ToolLayout
  title="Base64 to Image Converter &amp; Viewer — Decode Base64 Online Free"
  description="Free online Base64 to image converter. Paste any Base64 string to instantly preview and download the decoded picture. Works as a Base64 image viewer in your browser — no uploads."
  canonical="https://base64image.net/base64-image-decoder/"
  h1="Base64 to Image Decoder"
  mono="// atob()"
  lede="Paste any Base64 string and instantly preview and download the decoded picture. Works as a Base64 image viewer in your browser — no uploads, no server."
  tag="decode"
  tagLabel="Decoder"
  breadcrumbs={[{label:'Home',href:'/'},{label:'Decoders',href:'#'},{label:'Base64 → Image'}]}
>
  <Fragment slot="head">
    <script type="application/ld+json">{
      "@context": "https://schema.org", "@type": "HowTo",
      "name": "How to Decode Base64 to Image",
      "step": [
        {"@type":"HowToStep","name":"Paste Base64","text":"Paste your Base64 string into the text area."},
        {"@type":"HowToStep","name":"Click Decode","text":"Click the Decode Image button to validate and convert the string."},
        {"@type":"HowToStep","name":"Download","text":"Click Download Image to save the decoded image."}
      ]
    }</script>
    <script type="application/ld+json">{
      "@context": "https://schema.org", "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://base64image.net/"},
        {"@type":"ListItem","position":2,"name":"Base64 Image Decoder","item":"https://base64image.net/base64-image-decoder/"}
      ]
    }</script>
  </Fragment>

  <div class="tool-section">
    <div class="input-group">
      <label for="base64Input">Paste your Base64 string</label>
      <textarea id="base64Input" placeholder="Paste your Base64 string here (with or without data:image/png;base64, prefix)..." rows="6"></textarea>
      <div class="error" id="decodeError" style="display:none"></div>
    </div>
    <div class="actions">
      <button id="decodeBtn" class="btn-primary">Decode Image</button>
      <button id="clearBtn" class="btn-secondary">Clear</button>
    </div>
    <div class="preview-container" id="previewContainer" style="display:none">
      <h2>Preview</h2>
      <div class="image-wrapper"><img id="previewImg" alt="Decoded image preview"></div>
      <div class="image-info">
        <p><strong>Format:</strong> <span id="imageFormat"></span></p>
        <p><strong>Size:</strong> <span id="imageSize"></span></p>
      </div>
      <button id="downloadBtn" class="btn-primary">Download Image</button>
    </div>
  </div>

  <article class="content-section">
    <h2>What is a Base64 Image Decoder?</h2>
    <p>A Base64 image decoder converts Base64-encoded strings back into their original image format. Base64 encoding is widely used to embed images directly into HTML, CSS, or JSON files. You can <a href="/base64-validator/">validate any Base64 string</a> before decoding.</p>
    <h2>What Image Formats Are Supported?</h2>
    <p>PNG, JPEG, GIF, WebP, SVG, and BMP. The format is automatically detected from the data URI prefix (e.g., <code>data:image/png;base64,</code>) or from binary file signatures.</p>
    <h2>Frequently Asked Questions</h2>
    <div class="faq-item"><h3>Is my data safe?</h3><p>Yes. This tool runs entirely in your browser. No data is uploaded to any server.</p></div>
    <div class="faq-item"><h3>Can I decode without the data URI prefix?</h3><p>Yes. Paste the full data URI or just the raw Base64 string — the tool handles both.</p></div>
    <div class="faq-item"><h3>Why is my string showing an error?</h3><p>Errors occur if the string is malformed or contains invalid characters. Base64 strings should only contain A-Z, a-z, 0-9, +, /, and = (padding).</p></div>
  </article>

  <script is:inline>
  (function () {
    var _blob = null, _ext = 'png', _b64 = '', _mime = 'image/png';
    var textarea  = document.getElementById('base64Input');
    var errorDiv  = document.getElementById('decodeError');
    var container = document.getElementById('previewContainer');
    var img       = document.getElementById('previewImg');
    var fmtSpan   = document.getElementById('imageFormat');
    var sizeSpan  = document.getElementById('imageSize');
    var dlBtn     = document.getElementById('downloadBtn');
    var decodeBtn = document.getElementById('decodeBtn');
    var clrBtn    = document.getElementById('clearBtn');

    function resetPreview() {
      container.style.display = 'none';
      errorDiv.style.display  = 'none';
      errorDiv.textContent    = '';
      if (img.src && img.src.startsWith('blob:')) URL.revokeObjectURL(img.src);
      img.src = '';
      _blob = null; _b64 = ''; _mime = 'image/png';
    }

    function decode() {
      resetPreview();
      var input = textarea.value.trim();
      if (!input) return;
      try {
        var base64 = input, format = 'unknown';
        var m = input.match(/^data:image\/([a-zA-Z0-9+\-]+);base64,(.+)$/s);
        if (m) { format = m[1]; base64 = m[2].trim(); }
        // Strip whitespace that some tools insert (line-wrapped Base64)
        base64 = base64.replace(/\s/g, '');
        if (!/^[A-Za-z0-9+/]*={0,2}$/.test(base64)) throw new Error('Invalid Base64 characters detected.');
        var bin = atob(base64);
        var bytes = new Uint8Array(bin.length);
        for (var i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
        if (format === 'unknown') format = detectFmt(bytes);
        _mime = getMime(format);
        _b64  = base64;
        _ext  = format === 'jpeg' ? 'jpg' : format === 'svg+xml' ? 'svg' : format;
        _blob = new Blob([bytes], { type: _mime });
        // Blob URL for preview only — renders faster than data URI for large images
        img.src = URL.createObjectURL(_blob);
        fmtSpan.textContent  = format.toUpperCase();
        sizeSpan.textContent = fmtBytes(_blob.size);
        container.style.display = '';
      } catch (err) {
        errorDiv.textContent    = err.message || 'Failed to decode — check that the string is valid Base64.';
        errorDiv.style.display  = '';
      }
    }

    function detectFmt(b) {
      if (b[0]===0xFF&&b[1]===0xD8)                                         return 'jpeg';
      if (b[0]===0x89&&b[1]===0x50&&b[2]===0x4E&&b[3]===0x47)              return 'png';
      if (b[0]===0x47&&b[1]===0x49&&b[2]===0x46)                            return 'gif';
      if (b[0]===0x52&&b[1]===0x49&&b[2]===0x46&&b[3]===0x46)              return 'webp';
      if (b[0]===0x42&&b[1]===0x4D)                                          return 'bmp';
      if (b[0]===0x3C) /* < — likely SVG */                                  return 'svg+xml';
      return 'png';
    }

    function getMime(f) {
      return { png:'image/png', jpeg:'image/jpeg', gif:'image/gif',
               webp:'image/webp', bmp:'image/bmp', 'svg+xml':'image/svg+xml' }[f] || 'image/png';
    }

    function fmtBytes(n) {
      if (!n) return '0 B';
      var k=1024, s=['B','KB','MB'], i=Math.floor(Math.log(n)/Math.log(k));
      return Math.round((n/Math.pow(k,i))*100)/100+' '+s[i];
    }

    // Decode on button click only (not on every keystroke)
    decodeBtn.addEventListener('click', decode);

    // Also decode on Ctrl/Cmd+Enter for keyboard users
    textarea.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) decode();
    });

    // Download: use data URI — data is inline in the href, no async blob
    // Blob URL download: _blob is already decoded binary in memory.
    // URL.createObjectURL is O(1) — just a pointer, no re-decoding.
    // A fresh URL per click avoids the browser caching/serving issues
    // that plagued the old approach of reusing img.src.
    // Data URI downloads (previous approach) forced Chrome to re-parse
    // the entire base64 string as a URL on every click, causing queuing
    // lag when downloading multiple images in sequence.
    dlBtn.addEventListener('click', function() {
      if (!_blob) return;
      var url = URL.createObjectURL(_blob);
      var a   = document.createElement('a');
      a.href     = url;
      a.download = 'decoded-image-' + Date.now() + '.' + _ext;
      a.style.display = 'none';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      // Revoke after 30 s — well after Chrome has started the file write.
      setTimeout(function() { URL.revokeObjectURL(url); }, 30000);
    });

    clrBtn.addEventListener('click', function() {
      textarea.value = '';
      resetPreview();
    });
  })();
  </script>
</ToolLayout>
