                "text": "Yes! You can paste either the complete data URI (e.g., data:image/png;base64,iVBORw0KG...) or just the Base64 string itself. The tool automatically handles both formats."
            }
        }, {
            "@type": "Question",
            "name": "Why is my Base64 string showing an error?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Errors typically occur if the Base64 string is malformed, incomplete, or contains invalid characters. Ensure you've copied the entire string without truncation. Base64 strings should only contain A-Z, a-z, 0-9, +, /, and = (for padding)."
            }
        }]
    }
        </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://base64image.net/"
        }, {
            "@type": "ListItem",
            "position": 2,
            "name": "Base64 Image Decoder",
            "item": "https://base64image.net/base64-image-decoder/"
        }]
    }
        </script>
  </Fragment>
  <Fragment set:html={mainHtml} />
</BaseLayout>
