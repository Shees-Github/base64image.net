---
import ToolLayout from '../../layouts/ToolLayout.astro';
const bodyHtml = `<main x-data="base64Validator()">
        <h1><i class="fas fa-check-circle"></i> Base64 Validator</h1>
        <p class="intro">Validate Base64 strings and verify image data</p>

        <div class="trust-note">
            <strong>🔒 Privacy First:</strong> All validation happens locally in your browser. Your data never leaves your device.
        </div>

        <section class="tool-section">
            <div class="input-group">
                <label for="base64Input">Paste your Base64 string:</label>
                <textarea
                    id="base64Input"
                    x-model="base64Input"
                    @input="validateBase64"
                    placeholder="Paste your Base64 string here..."
                    rows="6"
                ></textarea>
            </div>

            <div class="preview-container" x-show="validationResult">
                <h2><i class="fas fa-clipboard-check"></i> Validation Result</h2>

                <div x-show="validationResult && validationResult.isValid" class="success" style="margin-bottom: 20px;">
                    ✓ Valid Base64 string
                </div>

                <div x-show="validationResult && !validationResult.isValid" class="error" style="margin-bottom: 20px;">
                    ✗ Invalid Base64 string
                </div>

                <div class="image-info" x-show="validationResult">
                    <p><strong>Status:</strong> <span x-text="validationResult.isValid ? 'Valid' : 'Invalid'"></span></p>
                    <p x-show="validationResult.hasDataUri"><strong>Data URI:</strong> <span x-text="validationResult.hasDataUri ? 'Yes' : 'No'"></span></p>
                    <p x-show="validationResult.format"><strong>Detected Format:</strong> <span x-text="validationResult.format"></span></p>
                    <p><strong>Length:</strong> <span x-text="validationResult.length"></span> characters</p>
                    <p x-show="validationResult.estimatedSize"><strong>Estimated Size:</strong> <span x-text="validationResult.estimatedSize"></span></p>
                    <p x-show="validationResult.error" style="color: #dc3545;"><strong>Error:</strong> <span x-text="validationResult.error"></span></p>
                </div>

                <div class="image-wrapper" x-show="validationResult && validationResult.isValid && validationResult.isImage">
                    <img :src="imagePreview" alt="Preview" x-show="imagePreview">
                </div>
            </div>

            <div class="actions">
                <button @click="clearAll" class="btn-secondary">Clear</button>
            </div>
        </section>

        <article class="content-section">
            <h2><i class="fas fa-question-circle"></i> What is Base64 Validation?</h2>
            <p>
                Base64 validation checks whether a string conforms to the Base64 encoding specification defined in RFC 4648. A valid Base64 string contains only 64 permitted characters (<code>A-Z</code>, <code>a-z</code>, <code>0-9</code>, <code>+</code>, <code>/</code>) plus <code>=</code> padding. This validator verifies the character set, padding correctness, and data integrity.
            </p>

            <h2><i class="fas fa-lightbulb"></i> Why Validate Base64 Strings?</h2>
            <p>
                Invalid Base64 strings cause decoding failures, application crashes, and corrupted data output. Validation catches 4 categories of errors before they reach production systems.
            </p>
            <ul>
                <li><strong>Truncated data:</strong> Incomplete API responses or copy-paste errors produce strings that fail decoding.</li>
                <li><strong>Character corruption:</strong> Non-Base64 characters inserted during transmission break the encoding.</li>
                <li><strong>Padding errors:</strong> Missing or misplaced <code>=</code> characters produce incorrect byte alignment.</li>
                <li><strong>Format mismatches:</strong> A string may be valid Base64 but not represent the expected data type (image, PDF, text).</li>
            </ul>
            <p>
                After validation, use the <a href="/base64-image-decoder/">Base64 image decoder</a> or <a href="/base64-file-decoder/">file decoder</a> to extract the original data.
            </p>

            <h2><i class="fas fa-cog"></i> How Does the Base64 Validator Work?</h2>
            <p>
                The validator runs 5 checks in sequence: character set verification, padding correctness, length divisibility by 4, successful <code>atob()</code> decoding, and file signature detection. If the string includes a data URI prefix, the validator extracts the MIME type automatically.
            </p>

            <h3>What Image Formats Does the Validator Detect?</h3>
            <p>
                The validator identifies image formats by reading the first 4 bytes of decoded data (the file signature or "magic number"). The table below lists the supported signatures.
            </p>
            <table class="reference-table">
                <thead><tr><th>Format</th><th>File Signature (Hex)</th><th>Magic Bytes</th></tr></thead>
                <tbody>
                    <tr><td>PNG</td><td><code>89 50 4E 47</code></td><td><code>\\\\x89PNG</code></td></tr>
                    <tr><td>JPEG</td><td><code>FF D8 FF</code></td><td><code>\\\\xFF\\\\xD8\\\\xFF</code></td></tr>
                    <tr><td>GIF</td><td><code>47 49 46</code></td><td><code>GIF</code></td></tr>
                    <tr><td>WebP</td><td><code>52 49 46 46</code></td><td><code>RIFF</code></td></tr>
                    <tr><td>BMP</td><td><code>42 4D</code></td><td><code>BM</code></td></tr>
                    <tr><td>SVG</td><td><code>3C 73 76 67</code></td><td><code>&lt;svg</code></td></tr>
                </tbody>
            </table>
            <p>
                For hex-level inspection of encoded data, use the <a href="/base64-hex-converter/">Base64 to HEX converter</a>.
            </p>

            <h2><i class="fas fa-exclamation-circle"></i> What Are Common Base64 Validation Errors?</h2>
            <p>
                The validator identifies 5 specific error types and provides feedback for each one. Invalid characters outside the 64-character alphabet cause immediate rejection. Padding errors occur when <code>=</code> appears in positions other than the final 2 characters. Length errors indicate the string is not a multiple of 4 characters. Whitespace or line breaks within the string cause parsing failures. Decoding failures suggest the data is corrupted even if the character set is valid.
            </p>

            <h2><i class="fas fa-code"></i> What is the Structure of a Valid Base64 String?</h2>
            <p>
                A valid Base64 string follows 4 structural rules defined in RFC 4648. The string uses only the 64-character alphabet plus optional <code>=</code> padding. The padded length is a multiple of 4. Padding (<code>=</code> or <code>==</code>) appears only at the end. Data URIs prepend a MIME type prefix: <code>data:image/png;base64,</code>.
            </p>
            <p>
                To <a href="/base64-text-encoder/">encode text to Base64</a> or <a href="/base64-url-safe/">convert to URL-safe Base64</a>, use the respective tools and then validate the output here.
            </p>

            <h2><i class="fas fa-shield-alt"></i> Is This Validator Private and Secure?</h2>
            <p>
                All validation runs locally in your browser using JavaScript. Zero data is transmitted to external servers. Your Base64 strings, decoded data, and image previews remain entirely on your device.
            </p>

            <h2>Frequently Asked Questions</h2>

            <div class="faq-item">
                <h3>How do I validate a Base64 string?</h3>
                <p>
                    Paste your Base64 string into the text area above. The validator instantly checks character validity, padding, length, and decodability. Results display within milliseconds.
                </p>
            </div>

            <div class="faq-item">
                <h3>What makes a Base64 string invalid?</h3>
                <p>
                    A Base64 string is invalid if it contains characters outside <code>A-Z</code>, <code>a-z</code>, <code>0-9</code>, <code>+</code>, <code>/</code>, and <code>=</code>. It is also invalid if the padded length is not a multiple of 4 or if <code>=</code> characters appear in incorrect positions.
                </p>
            </div>

            <div class="faq-item">
                <h3>Can this validator detect the image format?</h3>
                <p>
                    Yes. The validator detects image formats in 2 ways: by parsing the data URI MIME type prefix (e.g., <code>data:image/png;base64,</code>) and by reading the decoded binary file signature (magic bytes).
                </p>
            </div>

            <div class="faq-item">
                <h3>Why does my valid-looking Base64 fail validation?</h3>
                <p>
                    Common causes include invisible whitespace characters, line breaks inserted by email systems (MIME wraps at 76 characters), incomplete copy-paste truncation, or incorrect padding. The validator identifies the specific error type.
                </p>
            </div>

            <div class="faq-item">
                <h3>Is this validator safe for sensitive data?</h3>
                <p>
                    Yes. All validation runs in your browser. Zero data leaves your device. No network requests are made during validation.
                </p>
            </div>
        </article>
    </main>`;
---
<ToolLayout
  title="Base64 Validator - Validate Base64 Strings Online"
  description="Free online Base64 validator. Check if your Base64 strings are valid, detect image format, and verify encoding. Instant validation with detailed feedback."
  canonical="https://base64image.net/base64-validator/"
  h1="Base64 Validator"
  mono="// validate()"
  lede="Validate Base64 strings and verify image data"
  tag="tools"
  tagLabel="Utility"
  breadcrumbs={[{label:'Home',href:'/'},{label:'Tools',href:'#'},{label:'Validator'}]}
>
  <Fragment slot="head">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "How to Validate Base64 Strings",
        "description": "Step-by-step guide to validate Base64 strings and detect errors",
        "step": [{
            "@type": "HowToStep",
            "name": "Paste Base64 String",
            "text": "Copy and paste the Base64 string you want to validate into the text area."
        }, {
            "@type": "HowToStep",
            "name": "Instant Validation",
            "text": "The validator automatically checks character validity, padding correctness, and data integrity."
        }, {
            "@type": "HowToStep",
            "name": "Review Results",
            "text": "Check the validation results showing whether the string is valid, detected format, and estimated size."
        }, {
            "@type": "HowToStep",
            "name": "View Image Preview",
            "text": "If the Base64 string represents valid image data, preview the image to confirm it decodes correctly."
        }]
    }
        </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [{
            "@type": "Question",
            "name": "How do I validate a Base64 string?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Paste your Base64 string into the text area above. The validator instantly checks character validity, padding, length, and decodability. Results display within milliseconds."
            }
        }, {
            "@type": "Question",
            "name": "What makes a Base64 string invalid?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "A Base64 string is invalid if it contains characters outside A-Z, a-z, 0-9, +, /, and =. It is also invalid if the padded length is not a multiple of 4 or if = characters appear in incorrect positions."
            }
        }, {
            "@type": "Question",
            "name": "Can this validator detect the image format?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. The validator detects image formats in 2 ways: by parsing the data URI MIME type prefix and by reading the decoded binary file signature (magic bytes)."
            }
        }, {
            "@type": "Question",
            "name": "Why does my valid-looking Base64 fail validation?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Common causes include invisible whitespace characters, line breaks inserted by email systems (MIME wraps at 76 characters), incomplete copy-paste truncation, or incorrect padding. The validator identifies the specific error type."
            }
        }, {
            "@type": "Question",
            "name": "Is this validator safe for sensitive data?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. All validation runs in your browser. Zero data leaves your device. No network requests are made during validation."
            }
        }]
    }
        </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://base64image.net/"
        }, {
            "@type": "ListItem",
            "position": 2,
            "name": "Base64 Validator",
            "item": "https://base64image.net/base64-validator/"
        }]
    }
        </script>
  </Fragment>
  <Fragment set:html={bodyHtml} />
  <script is:inline>function base64Validator() {
            return {
                base64Input: '',
                validationResult: null,
                imagePreview: '',

                validateBase64() {
                    this.validationResult = null;
                    this.imagePreview = '';

                    if (!this.base64Input.trim()) {
                        return;
                    }

                    const result = {
                        isValid: false,
                        hasDataUri: false,
                        format: '',
                        length: 0,
                        estimatedSize: '',
                        error: '',
                        isImage: false
                    };

                    try {
                        let base64String = this.base64Input.trim();
                        const originalLength = base64String.length;

                        // Check for data URI
                        const dataUriMatch = base64String.match(/^data:image\/([a-zA-Z0-9+\-]+);base64,(.+)$/);
                        if (dataUriMatch) {
                            result.hasDataUri = true;
                            result.format = dataUriMatch[1].toUpperCase();
                            base64String = dataUriMatch[2];
                        }

                        result.length = originalLength;

                        // Validate Base64 characters
                        if (!/^[A-Za-z0-9+/]*={0,2}$/.test(base64String)) {
                            result.error = 'Contains invalid characters. Base64 only allows A-Z, a-z, 0-9, +, /, and =';
                            this.validationResult = result;
                            return;
                        }

                        // Check padding
                        const paddingMatch = base64String.match(/=+$/);
                        if (paddingMatch && paddingMatch[0].length > 2) {
                            result.error = 'Invalid padding. Maximum 2 padding characters allowed.';
                            this.validationResult = result;
                            return;
                        }

                        // Try to decode
                        try {
                            const decoded = atob(base64String);
                            result.isValid = true;
                            result.estimatedSize = this.formatBytes(decoded.length);

                            // Try to detect if it's an image
                            const bytes = new Uint8Array(decoded.length);
                            for (let i = 0; i < decoded.length; i++) {
                                bytes[i] = decoded.charCodeAt(i);
                            }

                            // Detect format from file signature if not already detected
                            if (!result.format) {
                                result.format = this.detectImageFormat(bytes);
                            }

                            // Try to preview image
                            if (result.format) {
                                result.isImage = true;
                                this.imagePreview = `data:image/${result.format.toLowerCase()};base64,${base64String}`;
                            }

                        } catch (decodeError) {
                            result.error = 'Failed to decode Base64 string. Data may be corrupted.';
                        }

                    } catch (err) {
                        result.error = err.message || 'Validation error';
                    }

                    this.validationResult = result;
                },

                detectImageFormat(bytes) {
                    if (bytes.length >= 2 && bytes[0] === 0xFF && bytes[1] === 0xD8) return 'JPEG';
                    if (bytes.length >= 4 && bytes[0] === 0x89 && bytes[1] === 0x50 && bytes[2] === 0x4E && bytes[3] === 0x47) return 'PNG';
                    if (bytes.length >= 3 && bytes[0] === 0x47 && bytes[1] === 0x49 && bytes[2] === 0x46) return 'GIF';
                    if (bytes.length >= 4 && bytes[0] === 0x52 && bytes[1] === 0x49 && bytes[2] === 0x46 && bytes[3] === 0x46) return 'WEBP';
                    if (bytes.length >= 2 && bytes[0] === 0x42 && bytes[1] === 0x4D) return 'BMP';
                    if (bytes.length >= 5 && bytes[0] === 0x3C && bytes[1] === 0x73 && bytes[2] === 0x76 && bytes[3] === 0x67) return 'SVG';
                    return '';
                },

                formatBytes(bytes) {
                    if (bytes === 0) return '0 Bytes';
                    const k = 1024;
                    const sizes = ['Bytes', 'KB', 'MB'];
                    const i = Math.floor(Math.log(bytes) / Math.log(k));
                    return Math.round((bytes / Math.pow(k, i)) * 100) / 100 + ' ' + sizes[i];
                },

                clearAll() {
                    this.base64Input = '';
                    this.validationResult = null;
                    this.imagePreview = '';
                }
            }
        }</script>
</ToolLayout>
