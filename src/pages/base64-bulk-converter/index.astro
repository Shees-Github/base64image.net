---
import BaseLayout from '../../layouts/BaseLayout.astro';
const mainHtml = `<main>
        <h1><i class="fas fa-layer-group"></i> Bulk Base64 Converter</h1>

        <p class="intro">
            Convert multiple files to Base64 at once. Upload several images, documents, or files and get Base64-encoded output for all of them simultaneously.
        </p>

        <div class="trust-note">
            <strong>🔒 Privacy First:</strong> All conversion happens locally in your browser. Your files never leave your device.
        </div>

        <div class="tool-section" x-data="bulkConverter()">
            <div class="input-group">
                <label><i class="fas fa-upload"></i> Upload Multiple Files</label>
                <input type="file" @change="handleFiles" multiple>
                <p style="margin-top: 5px; font-size: 0.85rem; color: #666;">
                    Select multiple files (images, documents, etc.) to convert to Base64
                </p>
            </div>

            <div x-show="files.length > 0" class="actions">
                <button @click="convertAll" class="btn-primary" :disabled="processing">
                    <span x-show="!processing"><i class="fas fa-sync-alt"></i> Convert All to Base64</span>
                    <span x-show="processing"><i class="fas fa-spinner fa-spin"></i> Converting...</span>
                </button>
                <button @click="clearAll" class="btn-secondary">
                    <i class="fas fa-trash"></i> Clear All
                </button>
            </div>

            <div x-show="error" class="error" x-text="error"></div>
            <div x-show="success" class="success" x-text="success"></div>

            <div x-show="files.length > 0" class="preview-container">
                <h2><i class="fas fa-list"></i> Files (<span x-text="files.length"></span>)</h2>

                <div style="max-height: 400px; overflow-y: auto;">
                    <template x-for="(file, index) in files" :key="index">
                        <div style="padding: 15px; margin: 10px 0; background: #f8f9ff; border-radius: 8px; border: 1px solid #e0e4ff;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                                <div>
                                    <strong><i class="fas fa-file"></i> <span x-text="file.name"></span></strong>
                                    <div style="font-size: 0.85rem; color: #666; margin-top: 5px;">
                                        <span x-text="formatBytes(file.size)"></span>
                                        <span x-show="file.base64"> • Base64 length: <span x-text="file.base64.length.toLocaleString()"></span></span>
                                    </div>
                                </div>
                                <div>
                                    <span x-show="file.status === 'pending'" style="color: #666;">
                                        <i class="fas fa-clock"></i> Pending
                                    </span>
                                    <span x-show="file.status === 'processing'" style="color: #667eea;">
                                        <i class="fas fa-spinner fa-spin"></i> Converting...
                                    </span>
                                    <span x-show="file.status === 'completed'" style="color: #28a745;">
                                        <i class="fas fa-check-circle"></i> Done
                                    </span>
                                </div>
                            </div>

                            <div x-show="file.base64" class="actions" style="gap: 10px;">
                                <button @click="copyBase64(index)" class="btn-secondary" style="font-size: 0.85rem;">
                                    <i class="fas fa-copy"></i> Copy Base64
                                </button>
                                <button @click="downloadBase64(index)" class="btn-secondary" style="font-size: 0.85rem;">
                                    <i class="fas fa-download"></i> Download .txt
                                </button>
                            </div>
                        </div>
                    </template>
                </div>

                <div x-show="converted > 0" class="actions" style="margin-top: 20px;">
                    <button @click="downloadAllAsJson" class="btn-primary">
                        <i class="fas fa-file-download"></i> Download All as JSON
                    </button>
                </div>
            </div>
        </div>

        <section class="content-section">
            <h2><i class="fas fa-question-circle"></i> What Is Bulk Base64 Conversion?</h2>
            <p>
                Bulk Base64 conversion is the process of encoding multiple files into Base64 strings in a single batch operation. Instead of converting one file at a time, the bulk converter reads each file through the browser's <code>FileReader</code> API and outputs a Base64 string for every file in the queue. The result is a collection of encoded strings you can copy individually or export as a single JSON file. This tool processes everything client-side, so no data leaves your device. If you need to <a href="/base64-file-encoder/">encode individual files to Base64</a>, a dedicated single-file tool is also available.
            </p>

            <h2><i class="fas fa-lightbulb"></i> What Are the Common Use Cases for Bulk Base64 Conversion?</h2>
            <p>
                Bulk Base64 conversion serves four primary scenarios. Each involves converting multiple files at once rather than processing them one by one.
            </p>
            <p>
                <strong>Batch Image Processing:</strong> Convert product images, thumbnails, or icon sets to Base64 for inline embedding in HTML or CSS. A set of 20 icons can be converted in one operation and used directly in stylesheets without additional HTTP requests. You can also <a href="/base64-image-encoder/">encode single images to Base64</a> when only one file is needed.
            </p>
            <p>
                <strong>API Payload Preparation:</strong> REST and GraphQL APIs that accept Base64-encoded file uploads require each file as a string. Bulk conversion generates all strings at once, ready for inclusion in JSON request bodies.
            </p>
            <p>
                <strong>Documentation Embedding:</strong> Technical documentation tools that support inline images accept Base64 data URIs. Convert an entire folder of screenshots or diagrams in one batch to embed them without external image hosting.
            </p>
            <p>
                <strong>Data Migration and Backup:</strong> When moving files between systems, Base64 provides a text-safe transport format. Bulk conversion creates a JSON export that preserves file names and encoded content together.
            </p>

            <h2><i class="fas fa-cog"></i> How Does the Bulk Base64 Converter Work?</h2>
            <p>
                The converter follows three steps. Each file is processed independently using the browser's native <code>FileReader</code> and <code>btoa()</code> functions. No server-side processing is involved.
            </p>
            <p>
                <strong>Step 1 -- Select Multiple Files:</strong> Click the file input and select multiple files using <code>Ctrl+Click</code> (Windows/Linux) or <code>Cmd+Click</code> (macOS). The tool accepts any file type: images, PDFs, text files, and binary files.
            </p>
            <p>
                <strong>Step 2 -- Click Convert:</strong> Press the "Convert All to Base64" button. The converter reads each file sequentially into an <code>ArrayBuffer</code>, converts the bytes to a binary string, and encodes it with <code>btoa()</code>. A status indicator shows progress for each file.
            </p>
            <p>
                <strong>Step 3 -- Download Results:</strong> Copy any individual Base64 string to the clipboard, download a single file as a <code>.txt</code>, or click "Download All as JSON" to export every file's name and Base64 data in one <code>.json</code> file.
            </p>

            <h2><i class="fas fa-table"></i> What Output Formats Are Available?</h2>
            <p>
                The bulk converter provides three output options. Each format suits a different integration workflow. You can also use the <a href="/base64-embed-generator/">embed code generator</a> to produce ready-to-use HTML or CSS snippets from Base64 strings.
            </p>
            <table class="reference-table">
                <thead>
                    <tr>
                        <th>Output Option</th>
                        <th>Format</th>
                        <th>Use Case</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Individual Strings</td>
                        <td>Raw Base64 per file</td>
                        <td>Copy-paste into code</td>
                    </tr>
                    <tr>
                        <td>JSON Export</td>
                        <td><code>{"filename": "base64..."}</code></td>
                        <td>API payloads, config files</td>
                    </tr>
                    <tr>
                        <td>Data URIs</td>
                        <td><code>data:[MIME];base64,...</code></td>
                        <td>HTML/CSS embedding</td>
                    </tr>
                </tbody>
            </table>

            <h2><i class="fas fa-exclamation-triangle"></i> What Are the Performance Considerations for Bulk Conversion?</h2>
            <p>
                Performance depends on file count, individual file size, and device memory. The converter processes files sequentially in the browser's main thread. Keep these numbers in mind for smooth operation.
            </p>
            <p>
                <strong>File Size:</strong> Individual files under <code>5 MB</code> convert in under 1 second on most devices. Files between <code>5 MB</code> and <code>50 MB</code> may take several seconds each. Base64 encoding increases output size by approximately <code>33%</code>, so a <code>3 MB</code> image produces a roughly <code>4 MB</code> string.
            </p>
            <p>
                <strong>Batch Size:</strong> Batches of <code>50-100</code> files process without issues on modern browsers. Batches above <code>200</code> files may cause tab slowdowns on devices with less than <code>8 GB</code> of RAM. Splitting large sets into smaller batches is recommended.
            </p>
            <p>
                <strong>Browser Limits:</strong> The <code>FileReader</code> API handles files up to approximately <code>500 MB</code>, but practical limits are lower due to memory constraints. Total batch memory consumption equals roughly <code>2.66x</code> the combined original file sizes (raw bytes plus Base64 output).
            </p>

            <h2><i class="fas fa-shield-alt"></i> Is Bulk Base64 Conversion Private and Secure?</h2>
            <p>
                Yes. Every file is read and encoded entirely within your browser. No data is transmitted to any server. The tool uses the native <code>FileReader</code> API to read files from your local filesystem and <code>btoa()</code> to perform the encoding. Network activity is zero during conversion. After you close or refresh the page, all file data and Base64 output are cleared from browser memory. This makes the tool suitable for confidential documents, internal assets, and personally identifiable information. To verify output integrity, you can <a href="/base64-validator/">validate Base64 output</a> with a dedicated checker. For more <a href="/">Base64 tools</a>, see the full collection on the homepage.
            </p>

            <h2><i class="fas fa-question-circle"></i> Frequently Asked Questions</h2>

            <div class="faq-item">
                <h3>How many files can I convert at once?</h3>
                <p>
                    There is no hard-coded file count limit. The practical limit depends on your browser's available memory. Most modern browsers handle <code>50-100</code> files per batch without issues. Batches above <code>200</code> files may cause tab slowdowns on devices with less than <code>8 GB</code> of RAM. For very large sets, split files into batches of <code>50</code> and process them sequentially.
                </p>
            </div>

            <div class="faq-item">
                <h3>What is the maximum file size for bulk conversion?</h3>
                <p>
                    Each file can be up to the browser's <code>FileReader</code> limit, which is typically around <code>500 MB</code>. For best performance, keep individual files under <code>5 MB</code> and total batch size under <code>100 MB</code>. Base64 encoding increases output size by approximately <code>33%</code>, so plan memory usage accordingly.
                </p>
            </div>

            <div class="faq-item">
                <h3>Does bulk conversion maintain the original file names?</h3>
                <p>
                    Yes. The converter preserves each original file name in the output. When you download results as JSON, each entry includes the <code>filename</code> property mapped to its Base64 string. Individual <code>.txt</code> downloads also retain the source file name with a <code>.base64.txt</code> extension appended.
                </p>
            </div>

            <div class="faq-item">
                <h3>Can I convert mixed file types in one batch?</h3>
                <p>
                    Yes. The bulk converter accepts any file type in a single batch. You can mix images (PNG, JPEG, WebP), documents (PDF, DOCX), text files, and binary files. Each file is independently read and encoded to Base64 regardless of its MIME type. The JSON export includes all files together.
                </p>
            </div>
        </section>
    </main>`;
---
<BaseLayout
  title="Bulk Base64 Converter - Batch Convert Files Online Free"
  description="Free bulk Base64 converter. Upload and convert multiple files to Base64 at once. Batch process images and documents in your browser."
  canonical="https://base64image.net/base64-bulk-converter/"
  ogType="website"
>
  <Fragment slot="head">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://base64image.net/"
        }, {
            "@type": "ListItem",
            "position": 2,
            "name": "Bulk Base64 Converter",
            "item": "https://base64image.net/base64-bulk-converter/"
        }]
    }
        </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "How to Bulk Convert Files to Base64",
        "description": "Step-by-step guide to batch convert multiple files to Base64 format online for free",
        "step": [{
            "@type": "HowToStep",
            "name": "Select Multiple Files",
            "text": "Click the file input and select multiple files at once using Ctrl+Click or Cmd+Click. The tool accepts images, documents, and other file types."
        }, {
            "@type": "HowToStep",
            "name": "Click Convert",
            "text": "Click the 'Convert All to Base64' button. Each file is processed sequentially in your browser with no server upload."
        }, {
            "@type": "HowToStep",
            "name": "Download Results as JSON",
            "text": "Copy individual Base64 strings or click 'Download All as JSON' to export all converted files in a single JSON file."
        }]
    }
        </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [{
            "@type": "Question",
            "name": "How many files can I convert at once?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "There is no hard-coded file count limit. The practical limit depends on your browser's available memory. Most modern browsers handle 50-100 files per batch without issues. Batches above 200 files may cause tab slowdowns on devices with less than 8 GB of RAM."
            }
        }, {
            "@type": "Question",
            "name": "What is the maximum file size for bulk conversion?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Each file can be up to the browser's FileReader limit, which is typically around 500 MB. For best performance, keep individual files under 5 MB and total batch size under 100 MB. Base64 encoding increases output size by approximately 33%."
            }
        }, {
            "@type": "Question",
            "name": "Does bulk conversion maintain the original file names?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. The converter preserves each original file name in the output. When you download results as JSON, each entry includes the filename property mapped to its Base64 string. Individual .txt downloads also retain the source file name."
            }
        }, {
            "@type": "Question",
            "name": "Can I convert mixed file types in one batch?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. The bulk converter accepts any file type in a single batch. You can mix images (PNG, JPEG, WebP), documents (PDF, DOCX), text files, and binary files. Each file is independently read and encoded to Base64 regardless of its MIME type."
            }
        }]
    }
        </script>
  </Fragment>
  <Fragment set:html={mainHtml} />

  <script is:inline>function bulkConverter() {
            return {
                files: [],
                processing: false,
                converted: 0,
                error: '',
                success: '',

                handleFiles(event) {
                    this.error = '';
                    this.success = '';

                    const selectedFiles = Array.from(event.target.files);
                    if (selectedFiles.length === 0) return;

                    this.files = selectedFiles.map(file => ({
                        name: file.name,
                        size: file.size,
                        file: file,
                        base64: null,
                        status: 'pending'
                    }));

                    this.success = `${selectedFiles.length} file(s) loaded. Click "Convert All to Base64" to start.`;
                },

                async convertAll() {
                    this.processing = true;
                    this.error = '';
                    this.converted = 0;

                    for (let i = 0; i < this.files.length; i++) {
                        this.files[i].status = 'processing';

                        try {
                            const base64 = await this.fileToBase64(this.files[i].file);
                            this.files[i].base64 = base64;
                            this.files[i].status = 'completed';
                            this.converted++;
                        } catch (err) {
                            this.files[i].status = 'error';
                            this.error = `Failed to convert ${this.files[i].name}: ${err.message}`;
                        }
                    }

                    this.processing = false;
                    if (this.converted === this.files.length) {
                        this.success = `All ${this.converted} file(s) converted successfully!`;
                    }
                },

                fileToBase64(file) {
                    return new Promise((resolve, reject) => {
                        const reader = new FileReader();
                        reader.onload = (e) => {
                            const arrayBuffer = e.target.result;
                            const bytes = new Uint8Array(arrayBuffer);
                            let binary = '';
                            for (let i = 0; i < bytes.length; i++) {
                                binary += String.fromCharCode(bytes[i]);
                            }
                            resolve(btoa(binary));
                        };
                        reader.onerror = reject;
                        reader.readAsArrayBuffer(file);
                    });
                },

                copyBase64(index) {
                    navigator.clipboard.writeText(this.files[index].base64).then(() => {
                        this.success = `Base64 for "${this.files[index].name}" copied to clipboard!`;
                        setTimeout(() => this.success = '', 2000);
                    });
                },

                downloadBase64(index) {
                    const blob = new Blob([this.files[index].base64], { type: 'text/plain' });
                    const url = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = url;
                    link.download = `${this.files[index].name}.base64.txt`;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    URL.revokeObjectURL(url);
                },

                downloadAllAsJson() {
                    const results = this.files
                        .filter(f => f.base64)
                        .map(f => ({
                            filename: f.name,
                            size: f.size,
                            base64: f.base64
                        }));

                    const json = JSON.stringify(results, null, 2);
                    const blob = new Blob([json], { type: 'application/json' });
                    const url = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = url;
                    link.download = `base64-bulk-export-${Date.now()}.json`;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    URL.revokeObjectURL(url);
                },

                formatBytes(bytes) {
                    if (bytes === 0) return '0 Bytes';
                    const k = 1024;
                    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                    const i = Math.floor(Math.log(bytes) / Math.log(k));
                    return Math.round((bytes / Math.pow(k, i)) * 100) / 100 + ' ' + sizes[i];
                },

                clearAll() {
                    this.files = [];
                    this.converted = 0;
                    this.error = '';
                    this.success = '';
                    this.processing = false;
                }
            }
        }</script>
</BaseLayout>

