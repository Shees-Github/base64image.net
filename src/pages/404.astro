---
import BaseLayout from '../layouts/BaseLayout.astro';
const mainHtml = `<main>
        <div class="error-page">
            <h1>404</h1>
            <h2>Page Not Found</h2>
            <p>The page you're looking for doesn't exist or has been moved. Try one of our Base64 tools below or head back to the homepage.</p>
            <a href="/" class="btn">Go to Homepage</a>

            <div class="error-tools">
                <h3>Popular Tools</h3>
                <ul>
                    <li><a href="/base64-image-encoder/">Image to Base64 Encoder</a></li>
                    <li><a href="/base64-image-decoder/">Base64 to Image Decoder</a></li>
                    <li><a href="/base64-text-encoder/">Text to Base64 Encoder</a></li>
                    <li><a href="/base64-text-decoder/">Base64 to Text Decoder</a></li>
                    <li><a href="/base64-to-png/">Base64 to PNG Converter</a></li>
                    <li><a href="/base64-validator/">Base64 Validator</a></li>
                </ul>
            </div>
        </div>
    </main>`;
---
<BaseLayout
  title="Page Not Found - BASE64IMAGE"
  description=""
  canonical="https://base64image.net/"
  ogType="website"
>
  <Fragment slot="head">
  </Fragment>
  <Fragment set:html={mainHtml} />
</BaseLayout>
