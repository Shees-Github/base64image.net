---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { LOCALES, NON_ENGLISH_LOCALES } from '../../i18n/locales';
import { PAGE_REGISTRY } from '../../i18n/pageRegistry';
import allTranslations from '../../i18n/translations/index';
import { renderHomeSections } from '../../i18n/homeTemplate';
import { TOOL_SECTIONS } from '../../i18n/toolContent';

export function getStaticPaths() {
  const paths: any[] = [];

  for (const locale of NON_ENGLISH_LOCALES) {
    const t = allTranslations[locale.code];
    if (!t) continue;

    for (const [slug, pageMeta] of Object.entries(PAGE_REGISTRY)) {
      const pageT = (t.pages as Record<string, any>)[slug];
      if (!pageT) continue;
      // Generate the page if it has article content OR if the interactive tool
      // section exists in toolContent.ts (real tool will be embedded).
      // Skip pages with no content at all to avoid thin-content pages.
      if (pageMeta.type !== 'home' && !pageT.bodyHtml && !TOOL_SECTIONS[slug]) continue;

      paths.push({
        params: { lang: locale.code, slug: slug || undefined },
        props: { lang: locale.code, slug, pageT, t, pageType: pageMeta.type },
      });
    }
  }

  return paths;
}

const { lang, slug, pageT, t, pageType } = Astro.props;
const locale = LOCALES[lang];
const canonical = `https://base64image.net/${lang}/${slug ? slug + '/' : ''}`;
const enUrl = slug ? `https://base64image.net/${slug}/` : 'https://base64image.net/';

const alternates = [
  { hreflang: 'en', href: enUrl },
  { hreflang: 'x-default', href: enUrl },
  ...NON_ENGLISH_LOCALES.map(l => ({
    hreflang: l.code,
    href: `https://base64image.net/${l.code}/${slug ? slug + '/' : ''}`,
  })),
];

const isHome = pageType === 'home';
const isTool = pageType === 'tool';

const translatedSlugsSet = new Set(Object.keys(t.pages as Record<string, unknown>));
const homeSectionsHtml = isHome ? renderHomeSections(t.homeExtra, lang, translatedSlugsSet) : '';
const toolSection = isTool ? TOOL_SECTIONS[slug] : null;
---

{isHome ? (
  <BaseLayout
    title={pageT.title}
    description={pageT.description}
    canonical={canonical}
    lang={lang}
    dir={locale.dir}
    alternates={alternates}
    currentSlug=""
  >
    <!-- Hero — same structure as English, translated text -->
    <section class="hero">
      <div class="hero-inner">
        <div>
          <div class="hero-eyebrow">
            <span class="pill"><span class="pulse"></span>Free</span>
            {t.homeExtra.eyebrowSub}
          </div>
          <h1>{pageT.h1}<br><span class="grad">{pageT.lede.split('.')[0]}</span></h1>
          <p class="lede">{pageT.lede}</p>
          <div class="hero-meta">
            <span class="item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>{t.homeExtra.meta1}</span>
            <span class="item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>{t.homeExtra.meta2}</span>
            <span class="item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>{t.homeExtra.meta3}</span>
          </div>
        </div>
        <!-- Live encoder widget — works in any language -->
        <div class="converter">
          <div class="converter-head">
            <div class="traffic"><span></span><span></span><span></span></div>
            <span class="title"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg><b>base64_encode</b></span>
            <span class="badge"><span style="width:6px;height:6px;border-radius:50%;background:var(--mint);display:inline-block"></span>LIVE</span>
          </div>
          <div class="dropzone">
            <label class="dropzone-inner" for="heroInput" id="heroDropzone">
              <div class="dropzone-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              </div>
              <p>Drop an image or <span>click to browse</span></p>
              <small>PNG · JPEG · SVG · WebP · GIF · any format</small>
              <input type="file" id="heroInput" accept="image/*">
            </label>
          </div>
          <div class="preview-row" id="heroPreviewRow" style="display:none">
            <div class="preview-thumb"><img id="heroThumb" alt="preview"></div>
            <div class="preview-meta">
              <span class="name" id="heroName">—</span>
              <div class="row">
                <span><span class="k">size</span> <span class="v" id="heroSize">—</span></span>
                <span class="size-arrow">→</span>
                <span><span class="k">b64</span> <span class="v" id="heroB64Size">—</span></span>
              </div>
            </div>
          </div>
          <div class="code-out" id="heroCodeOut" style="display:none">
            <div class="code-tabs">
              <button class="active" id="tabDataUri">data URI</button>
              <button id="tabRaw">raw Base64</button>
            </div>
            <div class="code-body" id="heroCode"><em>// encoded output appears here</em></div>
            <div class="code-actions">
              <button class="btn primary" id="heroCopy">Copy</button>
              <button class="btn" id="heroClear">Clear</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust strip + bento + how it works + FAQ (all translated) -->
    <Fragment set:html={homeSectionsHtml} />

    <script is:inline>
    (function(){
      var inp=document.getElementById('heroInput'),dz=document.getElementById('heroDropzone'),
          pr=document.getElementById('heroPreviewRow'),co=document.getElementById('heroCodeOut'),
          th=document.getElementById('heroThumb'),nm=document.getElementById('heroName'),
          sz=document.getElementById('heroSize'),b6=document.getElementById('heroB64Size'),
          cd=document.getElementById('heroCode'),cp=document.getElementById('heroCopy'),
          cl=document.getElementById('heroClear'),tu=document.getElementById('tabDataUri'),
          tr=document.getElementById('tabRaw'),_uri='',_raw='',_mode='uri';
      function fmt(n){return n<1024?n+' B':n<1048576?(n/1024).toFixed(1)+' KB':(n/1048576).toFixed(1)+' MB';}
      function process(f){var r=new FileReader();r.onload=function(e){_uri=e.target.result;var c=_uri.indexOf(',');_raw=_uri.slice(c+1);th.src=_uri;nm.textContent=f.name;sz.textContent=fmt(f.size);b6.textContent=fmt(_uri.length);upd();pr.style.display='grid';co.style.display='block';};r.readAsDataURL(f);}
      function upd(){cd.textContent=_mode==='uri'?_uri:_raw;}
      inp.addEventListener('change',function(){if(this.files[0])process(this.files[0]);});
      dz.addEventListener('dragover',function(e){e.preventDefault();this.classList.add('is-drag');});
      dz.addEventListener('dragleave',function(){this.classList.remove('is-drag');});
      dz.addEventListener('drop',function(e){e.preventDefault();this.classList.remove('is-drag');var f=e.dataTransfer.files[0];if(f&&f.type.startsWith('image/'))process(f);});
      tu.addEventListener('click',function(){_mode='uri';tu.classList.add('active');tr.classList.remove('active');upd();});
      tr.addEventListener('click',function(){_mode='raw';tr.classList.add('active');tu.classList.remove('active');upd();});
      cp.addEventListener('click',function(){navigator.clipboard.writeText(_mode==='uri'?_uri:_raw).then(function(){cp.textContent='Copied!';setTimeout(function(){cp.textContent='Copy';},1500);});});
      cl.addEventListener('click',function(){_uri='';_raw='';inp.value='';pr.style.display='none';co.style.display='none';th.src='';});
    })();
    </script>
  </BaseLayout>
) : (
  <ArticleLayout
    title={pageT.title}
    description={pageT.description}
    canonical={canonical}
    h1={pageT.h1}
    lede={pageT.lede}
    tag={isTool ? 'tool' : 'learn'}
    tagLabel={isTool ? 'Tool' : 'Reference'}
    breadcrumbs={[{ label: 'Home', href: `/${lang}/` }, { label: pageT.h1 }]}
    lang={lang}
    dir={locale.dir}
    alternates={alternates}
    currentSlug={slug || ''}
  >
    {isTool && toolSection ? (
      <>
        {toolSection.needsAlpine && (
          <Fragment slot="head">
            <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
          </Fragment>
        )}
        <Fragment set:html={toolSection.html} />
        <script is:inline set:html={toolSection.script}></script>
      </>
    ) : isTool && (
      <div class="tool-lang-hero">
        <p class="tool-lang-note">{t.common.toolNote}</p>
        <a href={enUrl} class="tool-lang-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          {t.common.useTool}
        </a>
      </div>
    )}
    <Fragment set:html={pageT.bodyHtml || ''} />
  </ArticleLayout>
)}
