  description="Decode a Base64 string and display the result as formatted JSON. Useful for debugging API responses, JWT payloads, and Base64-encoded JSON data."
  canonical="https://base64image.net/base64-to-json/"
  h1="Base64 to JSON Converter"
  mono="// JSON.parse(atob())"
  lede="Decode a Base64 string and pretty-print the result as formatted JSON. Perfect for debugging API responses and JWT payloads."
  tag="convert"
  tagLabel="Converter"
  breadcrumbs={[{label:'Home',href:'/'},{label:'Converters',href:'#'},{label:'Base64 → JSON'}]}
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
