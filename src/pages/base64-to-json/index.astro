  <Fragment set:html={bodyHtml} />
  <script is:inline>
    function b64jsonConvert() {
      var input = document.getElementById('b64jsonInput').value.trim();
      var errorEl = document.getElementById('b64jsonError');
      var outputEl = document.getElementById('b64jsonOutput');
      var outputGroup = document.getElementById('b64jsonOutputGroup');
      var copyBtn = document.getElementById('b64jsonCopy');

      errorEl.style.display = 'none';
      errorEl.textContent = '';
      outputEl.value = '';
      outputGroup.style.display = 'none';
      copyBtn.style.display = 'none';

      if (!input) return;

      // Normalize URL-safe Base64: replace - with + and _ with /
      var normalized = input.replace(/-/g, '+').replace(/_/g, '/');
      // Add padding if missing
      var padNeeded = (4 - (normalized.length % 4)) % 4;
      normalized += '==='.slice(0, padNeeded);

      var decoded;
      try {
        decoded = atob(normalized);
      } catch (e) {
        errorEl.textContent = 'Invalid Base64: ' + e.message;
        errorEl.style.display = 'block';
        return;
      }

      // Try to parse as JSON
      try {
        var obj = JSON.parse(decoded);
        outputEl.value = JSON.stringify(obj, null, 2);
      } catch (e) {
        // Not valid JSON — show raw decoded text with a note
        outputEl.value = decoded + '\n\n// Note: decoded content is not valid JSON — showing raw text.';
      }

      outputGroup.style.display = 'block';
      copyBtn.style.display = 'inline-block';
    }

    function b64jsonCopyOutput() {
      var outputEl = document.getElementById('b64jsonOutput');
      var copyBtn = document.getElementById('b64jsonCopy');
      navigator.clipboard.writeText(outputEl.value).then(function() {
        copyBtn.textContent = 'Copied!';
        setTimeout(function() {
          copyBtn.innerHTML = '<i class="fas fa-copy"></i> Copy Output';
        }, 2000);
      });
    }

    function b64jsonClearAll() {
      document.getElementById('b64jsonInput').value = '';
      document.getElementById('b64jsonOutput').value = '';
      document.getElementById('b64jsonError').style.display = 'none';
      document.getElementById('b64jsonError').textContent = '';
      document.getElementById('b64jsonOutputGroup').style.display = 'none';
      document.getElementById('b64jsonCopy').style.display = 'none';
    }
  </script>
</ToolLayout>
