        }, {
            "@type": "HowToStep",
            "name": "Download GIF",
            "text": "Click the 'Download GIF' button to save the image as a .gif file to your device."
        }]
    }
        </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://base64image.net/"
        }, {
            "@type": "ListItem",
            "position": 2,
            "name": "Base64 to GIF Converter",
            "item": "https://base64image.net/base64-to-gif/"
        }]
    }
        </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [{
            "@type": "Question",
            "name": "Does this tool support animated GIFs?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. When your Base64 string contains an animated GIF, the tool preserves all animation frames, timing, and loop settings. The downloaded file will play exactly as the original animated GIF. The preview also shows the animation."
            }
        }, {
            "@type": "Question",
            "name": "Why is GIF limited to 256 colors?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "GIF uses an indexed color model with a palette of up to 256 colors per frame. This design dates to 1987 when memory and bandwidth were limited. Each pixel stores an 8-bit index into the palette rather than full 24-bit color data, which keeps file sizes small for simple graphics but makes GIF unsuitable for photographs."
            }
        }, {
            "@type": "Question",
            "name": "Can I convert a JPEG or PNG to GIF using this tool?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "This tool is designed to decode Base64 strings that already contain GIF data. Converting from JPEG or PNG to GIF requires color quantization (reducing to 256 colors) and dithering, which are specialized operations not available through the browser Canvas API. The tool will warn you if the input is not in GIF format."
            }
        }, {
            "@type": "Question",
            "name": "Does GIF support transparency?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "GIF supports binary transparency only, meaning each pixel is either fully transparent or fully opaque. There is no partial transparency or alpha blending. One color in the 256-color palette is designated as transparent. For smooth transparency with anti-aliasing, use PNG or WebP instead."
            }
