---
import BaseLayout from './BaseLayout.astro';
const { title, description, canonical, h1, lede, breadcrumbs = [] } = Astro.props;
---
<BaseLayout title={title} description={description} canonical={canonical}>
  <slot name="head" slot="head" />
  <main class="page">
    <nav class="breadcrumbs">
      {breadcrumbs.map((b, i) => (
        <>
          {i < breadcrumbs.length - 1
            ? <a href={b.href}>{b.label}</a>
            : <span class="current">{b.label}</span>}
          {i < breadcrumbs.length - 1 && <span class="sep">/</span>}
        </>
      ))}
    </nav>
    <header class="page-head">
      <div>
        <h1>{h1}</h1>
        {lede && <p class="lede">{lede}</p>}
      </div>
    </header>
    <div class="info-grid">
      <aside class="info-side"><slot name="side" /></aside>
      <article class="prose"><slot /></article>
    </div>
  </main>
</BaseLayout>
